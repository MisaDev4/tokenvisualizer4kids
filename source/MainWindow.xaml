<Window x:Class="TokenTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Token Tracker"
        Width="1280"
        Height="820"
        MinWidth="980"
        MinHeight="640"
        Background="{StaticResource WindowBackground}"
        Foreground="{StaticResource TextBrush}"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
  <Window.Resources>
    <Style x:Key="MetricCard" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource PanelBackground}" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="16" />
      <Setter Property="Margin" Value="0,0,10,0" />
    </Style>
    <Style x:Key="MetricLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style x:Key="MetricValue" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="FontSize" Value="25" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Margin" Value="0,7,0,0" />
    </Style>
  </Window.Resources>

  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="0,0,0,20">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel>
        <StackPanel Orientation="Horizontal">
          <Border Width="10" Height="10" CornerRadius="5" Background="{StaticResource AccentBrush}"
                  VerticalAlignment="Center" Margin="0,0,9,0" />
          <TextBlock Text="TOKEN TRACKER" FontSize="12" FontWeight="Bold"
                     Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" />
        </StackPanel>
        <TextBlock Text="Your local AI token history" FontSize="28" FontWeight="Bold" Margin="0,5,0,0" />
        <TextBlock Text="Codex + Claude logs, stored locally and kept up to date in the background."
                   Foreground="{StaticResource MutedBrush}" Margin="0,5,0,0" />
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
        <Button x:Name="RefreshButton" Content="Refresh now" Click="RefreshButton_Click" Margin="0,0,10,0" />
        <Button x:Name="FullRescanButton" Content="Full rescan / repair" Style="{StaticResource AccentButton}"
                Click="FullRescanButton_Click" ToolTip="Re-read every available log and repair the local index." />
      </StackPanel>
    </Grid>

    <Border Grid.Row="1" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,0,0,18">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="190" />
          <ColumnDefinition Width="24" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="170" />
          <ColumnDefinition Width="24" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="Show" Foreground="{StaticResource MutedBrush}"
                   VerticalAlignment="Center" Margin="0,0,9,0" />
        <ComboBox x:Name="RangeComboBox" Grid.Column="1" SelectionChanged="RangeComboBox_SelectionChanged" />
        <TextBlock Grid.Column="3" Text="Safety check" Foreground="{StaticResource MutedBrush}"
                   VerticalAlignment="Center" Margin="0,0,9,0" />
        <ComboBox x:Name="IntervalComboBox" Grid.Column="4" SelectionChanged="IntervalComboBox_SelectionChanged" />
        <CheckBox x:Name="StartupCheckBox" Grid.Column="6" Content="Start with Windows"
                  Checked="StartupCheckBox_Changed" Unchecked="StartupCheckBox_Changed" />
        <TextBlock Grid.Column="7" x:Name="LastUpdatedText" HorizontalAlignment="Right" VerticalAlignment="Center"
                   Foreground="{StaticResource MutedBrush}" />
      </Grid>
    </Border>

    <UniformGrid Grid.Row="2" Columns="7" Margin="0,0,0,18">
      <Border Style="{StaticResource MetricCard}" BorderBrush="{StaticResource AccentBrush}">
        <StackPanel><TextBlock Text="EST. COST" Style="{StaticResource MetricLabel}" Foreground="{StaticResource AccentBrush}" />
          <TextBlock x:Name="EstimatedCostText" Text="--" Style="{StaticResource MetricValue}"
                     Foreground="{StaticResource AccentBrush}" /></StackPanel>
      </Border>
      <Border Style="{StaticResource MetricCard}">
        <StackPanel><TextBlock Text="ALL TOKENS" Style="{StaticResource MetricLabel}" />
          <TextBlock x:Name="TotalTokensText" Text="—" Style="{StaticResource MetricValue}" /></StackPanel>
      </Border>
      <Border Style="{StaticResource MetricCard}">
        <StackPanel><TextBlock Text="INPUT" Style="{StaticResource MetricLabel}" />
          <TextBlock x:Name="InputTokensText" Text="—" Style="{StaticResource MetricValue}" /></StackPanel>
      </Border>
      <Border Style="{StaticResource MetricCard}">
        <StackPanel><TextBlock Text="OUTPUT" Style="{StaticResource MetricLabel}" />
          <TextBlock x:Name="OutputTokensText" Text="—" Style="{StaticResource MetricValue}" /></StackPanel>
      </Border>
      <Border Style="{StaticResource MetricCard}" BorderBrush="#7C5CE7">
        <StackPanel><TextBlock Text="REASONING" Style="{StaticResource MetricLabel}" Foreground="#AE9BFF" />
          <TextBlock x:Name="ReasoningTokensText" Text="—" Style="{StaticResource MetricValue}" Foreground="#C8BCFF" /></StackPanel>
      </Border>
      <Border Style="{StaticResource MetricCard}">
        <StackPanel><TextBlock Text="CACHE READ" Style="{StaticResource MetricLabel}" />
          <TextBlock x:Name="CacheReadTokensText" Text="—" Style="{StaticResource MetricValue}" /></StackPanel>
      </Border>
      <Border Style="{StaticResource MetricCard}" Margin="0">
        <StackPanel><TextBlock Text="CACHE WRITE" Style="{StaticResource MetricLabel}" />
          <TextBlock x:Name="CacheWriteTokensText" Text="—" Style="{StaticResource MetricValue}" /></StackPanel>
      </Border>
    </UniformGrid>

    <Grid Grid.Row="3">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="3*" />
        <ColumnDefinition Width="16" />
        <ColumnDefinition Width="2*" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="1" CornerRadius="12" Padding="1">
        <Grid>
          <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
          <StackPanel Margin="15,13,15,11">
            <TextBlock Text="Usage by model" FontSize="17" FontWeight="SemiBold" />
            <TextBlock x:Name="SummaryText" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,3,0,0" />
          </StackPanel>
          <DataGrid x:Name="ModelsGrid" Grid.Row="1" BorderThickness="0" AlternationCount="2">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Client" Binding="{Binding Client}" Width="75" />
              <DataGridTextColumn Header="Provider" Binding="{Binding Provider}" Width="85" />
              <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="*" MinWidth="150" />
              <DataGridTextColumn Header="Cost" Binding="{Binding EstimatedCost, StringFormat={}{0:C2}}" Width="90" />
              <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat={}{0:N0}}" Width="105" />
              <DataGridTextColumn Header="Reasoning" Binding="{Binding Reasoning, StringFormat={}{0:N0}}" Width="100" />
              <DataGridTextColumn Header="Messages" Binding="{Binding Messages, StringFormat={}{0:N0}}" Width="85" />
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </Border>

      <Border Grid.Column="2" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="1" CornerRadius="12" Padding="1">
        <Grid>
          <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
          <StackPanel Margin="15,13,15,11">
            <TextBlock Text="Daily totals" FontSize="17" FontWeight="SemiBold" />
            <TextBlock Text="Local calendar days" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,3,0,0" />
          </StackPanel>
          <DataGrid x:Name="DailyGrid" Grid.Row="1" BorderThickness="0" AlternationCount="2">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="*" />
              <DataGridTextColumn Header="Cost" Binding="{Binding EstimatedCost, StringFormat={}{0:C2}}" Width="90" />
              <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat={}{0:N0}}" Width="110" />
              <DataGridTextColumn Header="Reasoning" Binding="{Binding Reasoning, StringFormat={}{0:N0}}" Width="95" />
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </Border>
    </Grid>

    <Grid Grid.Row="4" Margin="0,16,0,0">
      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
      <StackPanel>
        <StackPanel Orientation="Horizontal">
          <ProgressBar x:Name="ScanProgress" Width="170" Height="7" Minimum="0" Maximum="1"
                       Value="0" Foreground="{StaticResource AccentBrush}" Background="{StaticResource PanelRaised}"
                       VerticalAlignment="Center" Margin="0,0,10,0" />
          <TextBlock x:Name="StatusText" Text="Starting…" Foreground="{StaticResource MutedBrush}" />
        </StackPanel>
        <TextBlock Text="Cost is an estimated API list price; reasoning is included in output tokens and billed at the output rate. Raw prompts are never copied into the database."
                   Foreground="#6F8D82" FontSize="11" Margin="0,7,0,0" />
      </StackPanel>
      <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
        <TextBlock x:Name="PricingStatusText" Foreground="#6F8D82" FontSize="11"
                   HorizontalAlignment="Right" />
        <TextBlock x:Name="DatabasePathText" Foreground="#6F8D82" FontSize="11" Margin="0,3,0,0"
                   TextTrimming="CharacterEllipsis" MaxWidth="420" />
      </StackPanel>
    </Grid>
  </Grid>
</Window>
