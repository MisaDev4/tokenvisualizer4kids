<Window x:Class="TokenTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Token Tracker"
        Width="1280"
        Height="860"
        MinWidth="1000"
        MinHeight="680"
        Background="{StaticResource PageBrush}"
        Foreground="{StaticResource Ink2Brush}"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
  <Window.Resources>
    <Style x:Key="GhostToggle" TargetType="ToggleButton">
      <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ToggleButton">
            <Border x:Name="Border" Background="Transparent" BorderBrush="Transparent"
                    BorderThickness="1" CornerRadius="7" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Border" Property="Background" Value="{StaticResource RaisedBrush}" />
              </Trigger>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Border" Property="Background" Value="{StaticResource RaisedBrush}" />
                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource HairlineBrush}" />
                <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Share bar used in the model breakdown; Foreground carries the model's series color -->
    <Style x:Key="ShareBar" TargetType="ProgressBar">
      <Setter Property="Height" Value="6" />
      <Setter Property="Minimum" Value="0" />
      <Setter Property="Maximum" Value="1" />
      <Setter Property="Foreground" Value="{StaticResource Series1Brush}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ProgressBar">
            <Grid>
              <Border x:Name="PART_Track" Background="{StaticResource BarTrackBrush}" CornerRadius="3" />
              <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                      CornerRadius="3" HorizontalAlignment="Left" />
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid Margin="20,16,20,14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- ═══ Header: brand · range presets · actions ═══ -->
    <Grid Grid.Row="0" Margin="0,0,0,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <Border Width="9" Height="9" CornerRadius="4.5" Background="{StaticResource AccentBrush}"
                VerticalAlignment="Center" Margin="0,1,10,0" />
        <TextBlock Text="Token Tracker" FontSize="15" FontWeight="SemiBold"
                   Foreground="{StaticResource InkBrush}" VerticalAlignment="Center" />
        <Border Style="{StaticResource SegmentGroup}" Margin="18,0,0,0">
          <StackPanel Orientation="Horizontal">
            <RadioButton x:Name="TabDashboard" Style="{StaticResource SegmentButton}" GroupName="tab"
                         Content="Dashboard" Tag="dashboard" IsChecked="True" Checked="TabButton_Checked" />
            <RadioButton x:Name="TabLive" Style="{StaticResource SegmentButton}" GroupName="tab"
                         Content="Live" Tag="live" Checked="TabButton_Checked"
                         ToolTip="Ultra real time: every response drops into the cup the moment it is logged." />
            <RadioButton x:Name="TabTerminals" Style="{StaticResource SegmentButton}" GroupName="tab"
                         Content="Terminals" Tag="terminals" Checked="TabButton_Checked"
                         ToolTip="Every Claude Code terminal on this machine: busy, waiting, or ready to prompt." />
            <RadioButton x:Name="TabLimits" Style="{StaticResource SegmentButton}" GroupName="tab"
                         Content="Limits" Tag="limits" Checked="TabButton_Checked"
                         ToolTip="Your Claude plan rate limits, with reset countdowns." />
          </StackPanel>
        </Border>
      </StackPanel>

      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
        <Border x:Name="RangeGroupBorder" Style="{StaticResource SegmentGroup}">
          <StackPanel Orientation="Horizontal">
            <RadioButton x:Name="RangeLast1" Style="{StaticResource SegmentButton}" GroupName="range"
                         Content="1 h" Tag="last1" Checked="RangeButton_Checked" />
            <RadioButton x:Name="RangeLast4" Style="{StaticResource SegmentButton}" GroupName="range"
                         Content="4 h" Tag="last4" Checked="RangeButton_Checked" />
            <RadioButton x:Name="RangeLast8" Style="{StaticResource SegmentButton}" GroupName="range"
                         Content="8 h" Tag="last8" Checked="RangeButton_Checked" />
            <RadioButton x:Name="RangeLast12" Style="{StaticResource SegmentButton}" GroupName="range"
                         Content="12 h" Tag="last12" Checked="RangeButton_Checked" />
            <RadioButton x:Name="RangeLast24" Style="{StaticResource SegmentButton}" GroupName="range"
                         Content="24 h" Tag="last24" Checked="RangeButton_Checked" />
            <RadioButton x:Name="RangeToday" Style="{StaticResource SegmentButton}" GroupName="range"
                         Content="Today" Tag="today" Checked="RangeButton_Checked" />
            <RadioButton x:Name="RangeLast7" Style="{StaticResource SegmentButton}" GroupName="range"
                         Content="7 d" Tag="last7" ToolTip="Last 7 days" Checked="RangeButton_Checked" />
            <RadioButton x:Name="RangeLast30" Style="{StaticResource SegmentButton}" GroupName="range"
                         Content="30 d" Tag="last30" ToolTip="Last 30 days" Checked="RangeButton_Checked" />
            <RadioButton x:Name="RangeMonth" Style="{StaticResource SegmentButton}" GroupName="range"
                         Content="Month" Tag="currentMonth" ToolTip="This calendar month" Checked="RangeButton_Checked" />
            <RadioButton x:Name="RangeAll" Style="{StaticResource SegmentButton}" GroupName="range"
                         Content="All" Tag="all" ToolTip="All time" Checked="RangeButton_Checked" />
          </StackPanel>
        </Border>
        <Button x:Name="RefreshButton" Content="Refresh" Style="{StaticResource GhostButton}"
                Margin="10,0,0,0" Click="RefreshButton_Click" />
        <ToggleButton x:Name="SettingsToggle" Style="{StaticResource GhostToggle}" Margin="4,0,0,0"
                      Content="Settings" Padding="10,7" />
        <Popup x:Name="SettingsPopup"
               PlacementTarget="{Binding ElementName=SettingsToggle}"
               Placement="Bottom"
               HorizontalOffset="-220"
               VerticalOffset="6"
               AllowsTransparency="True"
               StaysOpen="False"
               IsOpen="{Binding IsChecked, ElementName=SettingsToggle, Mode=TwoWay}">
          <Border Style="{StaticResource Card}" Background="#1F1F1E" Width="320" Padding="18" Margin="0,0,0,8">
            <StackPanel>
              <TextBlock Text="Settings" FontSize="14" FontWeight="SemiBold"
                         Foreground="{StaticResource InkBrush}" />
              <TextBlock Text="Background safety check" Style="{StaticResource TileLabel}" Margin="0,14,0,6" />
              <ComboBox x:Name="IntervalComboBox" SelectionChanged="IntervalComboBox_SelectionChanged" />
              <CheckBox x:Name="StartupCheckBox" Content="Start with Windows" Margin="0,14,0,0"
                        Checked="StartupCheckBox_Changed" Unchecked="StartupCheckBox_Changed" />
              <Button x:Name="FullRescanButton" Content="Full rescan / repair" Margin="0,16,0,0"
                      HorizontalAlignment="Stretch"
                      ToolTip="Re-read every available log and repair the local index."
                      Click="FullRescanButton_Click" />
              <Border Height="1" Background="{StaticResource GridlineBrush}" Margin="0,16,0,12" />
              <TextBlock x:Name="PricingStatusText" FontSize="11" Foreground="{StaticResource MutedBrush}"
                         TextWrapping="Wrap" />
              <TextBlock x:Name="DatabasePathText" FontSize="11" Foreground="{StaticResource MutedBrush}"
                         TextWrapping="Wrap" Margin="0,4,0,0" />
              <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,10,0,0"
                         Text="Costs are estimated API list prices. Reasoning tokens are part of output and billed at the output rate. Raw prompts are never copied into the database." />
            </StackPanel>
          </Border>
        </Popup>
      </StackPanel>
    </Grid>

    <!-- ═══ Hero cost + KPI tiles ═══ -->
    <Border x:Name="DashboardHero" Grid.Row="1" Style="{StaticResource Card}" Padding="24,18" Margin="0,0,0,14">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" VerticalAlignment="Center" MinWidth="210">
          <TextBlock x:Name="CostLabel" Text="Estimated cost" Style="{StaticResource TileLabel}" />
          <TextBlock x:Name="CostText" Text="—" FontSize="44" FontWeight="SemiBold"
                     Foreground="{StaticResource InkBrush}" Margin="0,2,0,0" />
          <TextBlock x:Name="CostDeltaText" Text="" FontSize="12"
                     Foreground="{StaticResource MutedBrush}" Margin="2,2,0,0" />
        </StackPanel>
        <Border Grid.Column="1" Width="1" Background="{StaticResource GridlineBrush}"
                Margin="24,4" />
        <UniformGrid Grid.Column="2" Columns="6" VerticalAlignment="Center">
          <StackPanel Margin="6,0">
            <TextBlock Text="Total tokens" Style="{StaticResource TileLabel}" />
            <TextBlock x:Name="TotalTokensText" Text="—" Style="{StaticResource TileValue}" />
          </StackPanel>
          <StackPanel Margin="6,0">
            <TextBlock Text="Input" Style="{StaticResource TileLabel}" />
            <TextBlock x:Name="InputTokensText" Text="—" Style="{StaticResource TileValue}" />
          </StackPanel>
          <StackPanel Margin="6,0">
            <TextBlock Text="Output" Style="{StaticResource TileLabel}" />
            <TextBlock x:Name="OutputTokensText" Text="—" Style="{StaticResource TileValue}" />
          </StackPanel>
          <StackPanel Margin="6,0">
            <TextBlock Text="Reasoning" Style="{StaticResource TileLabel}"
                       ToolTip="Included in output tokens." />
            <TextBlock x:Name="ReasoningTokensText" Text="—" Style="{StaticResource TileValue}" />
          </StackPanel>
          <StackPanel Margin="6,0">
            <TextBlock Text="Cache read" Style="{StaticResource TileLabel}" />
            <TextBlock x:Name="CacheReadTokensText" Text="—" Style="{StaticResource TileValue}" />
          </StackPanel>
          <StackPanel Margin="6,0">
            <TextBlock Text="Cache write" Style="{StaticResource TileLabel}" />
            <TextBlock x:Name="CacheWriteTokensText" Text="—" Style="{StaticResource TileValue}" />
          </StackPanel>
        </UniformGrid>
      </Grid>
    </Border>

    <!-- ═══ Chart + model breakdown ═══ -->
    <Grid x:Name="DashboardContent" Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="3*" />
        <ColumnDefinition Width="14" />
        <ColumnDefinition Width="2*" MinWidth="330" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Style="{StaticResource Card}" Padding="20,16">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <Grid Grid.Row="0" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock x:Name="ChartTitle" Text="Spend by hour" FontSize="16" FontWeight="SemiBold"
                         Foreground="{StaticResource InkBrush}" />
              <TextBlock x:Name="ChartSubtitle" Text="" FontSize="12"
                         Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
              <Border Style="{StaticResource SegmentGroup}" Margin="0,0,8,0"
                      ToolTip="Bar size. Auto picks a width to fit the range; only sizes that make sense for the range are offered.">
                <StackPanel Orientation="Horizontal">
                  <RadioButton x:Name="BarsAuto" Style="{StaticResource SegmentButton}" GroupName="bars"
                               Content="Auto" Tag="auto" IsChecked="True" Checked="BarsButton_Checked" />
                  <RadioButton x:Name="BarsS15" Style="{StaticResource SegmentButton}" GroupName="bars"
                               Content="15s" Tag="s15" Checked="BarsButton_Checked" />
                  <RadioButton x:Name="BarsS30" Style="{StaticResource SegmentButton}" GroupName="bars"
                               Content="30s" Tag="s30" Checked="BarsButton_Checked" />
                  <RadioButton x:Name="BarsM1" Style="{StaticResource SegmentButton}" GroupName="bars"
                               Content="1m" Tag="m1" Checked="BarsButton_Checked" />
                  <RadioButton x:Name="BarsM5" Style="{StaticResource SegmentButton}" GroupName="bars"
                               Content="5m" Tag="m5" Checked="BarsButton_Checked" />
                  <RadioButton x:Name="BarsM15" Style="{StaticResource SegmentButton}" GroupName="bars"
                               Content="15m" Tag="m15" Checked="BarsButton_Checked" />
                  <RadioButton x:Name="BarsM30" Style="{StaticResource SegmentButton}" GroupName="bars"
                               Content="30m" Tag="m30" Checked="BarsButton_Checked" />
                  <RadioButton x:Name="BarsH1" Style="{StaticResource SegmentButton}" GroupName="bars"
                               Content="1h" Tag="h1" Checked="BarsButton_Checked" />
                  <RadioButton x:Name="BarsD1" Style="{StaticResource SegmentButton}" GroupName="bars"
                               Content="1d" Tag="d1" Checked="BarsButton_Checked" />
                </StackPanel>
              </Border>
              <Border Style="{StaticResource SegmentGroup}">
                <StackPanel Orientation="Horizontal">
                  <RadioButton x:Name="MetricCost" Style="{StaticResource SegmentButton}" GroupName="metric"
                               Content="Cost" Tag="cost" IsChecked="True" Checked="MetricButton_Checked" />
                  <RadioButton x:Name="MetricTokens" Style="{StaticResource SegmentButton}" GroupName="metric"
                               Content="Tokens" Tag="tokens" Checked="MetricButton_Checked" />
                  <RadioButton x:Name="MetricMessages" Style="{StaticResource SegmentButton}" GroupName="metric"
                               Content="Messages" Tag="messages" Checked="MetricButton_Checked" />
                </StackPanel>
              </Border>
              <ToggleButton x:Name="TableToggle" Style="{StaticResource GhostToggle}" Content="Table"
                            Margin="8,0,0,0" Checked="TableToggle_Changed" Unchecked="TableToggle_Changed" />
            </StackPanel>
          </Grid>

          <ItemsControl x:Name="ChartLegend" Grid.Row="1" Margin="2,4,0,2" Visibility="Collapsed">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal" Margin="0,0,16,3">
                  <Rectangle Width="10" Height="10" RadiusX="2" RadiusY="2" Fill="{Binding Brush}"
                             VerticalAlignment="Center" />
                  <TextBlock Text="{Binding Name}" FontSize="11" Foreground="{StaticResource Ink2Brush}"
                             Margin="6,0,0,0" />
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <Grid Grid.Row="2" Margin="0,6,0,0">
            <Canvas x:Name="ChartCanvas" ClipToBounds="True" Background="Transparent"
                    SizeChanged="ChartCanvas_SizeChanged" />
            <TextBlock x:Name="ChartEmptyText" Text="No usage recorded in this range."
                       Foreground="{StaticResource MutedBrush}" FontSize="13"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="Collapsed" />
            <DataGrid x:Name="ChartTable" Visibility="Collapsed">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Period" Binding="{Binding Period}" Width="*" />
                <DataGridTextColumn Header="Cost" Binding="{Binding Cost}" Width="80">
                  <DataGridTextColumn.ElementStyle>
                    <Style TargetType="TextBlock"><Setter Property="TextAlignment" Value="Right" /></Style>
                  </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="90">
                  <DataGridTextColumn.ElementStyle>
                    <Style TargetType="TextBlock"><Setter Property="TextAlignment" Value="Right" /></Style>
                  </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Input" Binding="{Binding Input}" Width="90">
                  <DataGridTextColumn.ElementStyle>
                    <Style TargetType="TextBlock"><Setter Property="TextAlignment" Value="Right" /></Style>
                  </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Output" Binding="{Binding Output}" Width="90">
                  <DataGridTextColumn.ElementStyle>
                    <Style TargetType="TextBlock"><Setter Property="TextAlignment" Value="Right" /></Style>
                  </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Cache" Binding="{Binding Cache}" Width="100">
                  <DataGridTextColumn.ElementStyle>
                    <Style TargetType="TextBlock"><Setter Property="TextAlignment" Value="Right" /></Style>
                  </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Msgs" Binding="{Binding Messages}" Width="70">
                  <DataGridTextColumn.ElementStyle>
                    <Style TargetType="TextBlock"><Setter Property="TextAlignment" Value="Right" /></Style>
                  </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </Grid>
      </Border>

      <Border x:Name="ModelsCard" Grid.Column="2" Style="{StaticResource Card}" Padding="20,16">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <Grid x:Name="ModelsHeaderGrid" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="By model" FontSize="16" FontWeight="SemiBold"
                         Foreground="{StaticResource InkBrush}" />
              <TextBlock x:Name="ModelsSubtitle" Text="" FontSize="12"
                         Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0" />
            </StackPanel>
            <!-- Swaps this panel between the model breakdown and the live cup;
                 rides along into whichever card is showing. -->
            <Border x:Name="PanelGroup" Grid.Column="1" Style="{StaticResource SegmentGroup}"
                    VerticalAlignment="Top" Margin="12,0,0,0"
                    ToolTip="This panel: the per-model breakdown or the live cup.">
              <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="PanelModels" Style="{StaticResource SegmentButton}" GroupName="dashPanel"
                             Content="By model" Tag="models" IsChecked="True" Checked="PanelButton_Checked" />
                <RadioButton x:Name="PanelLive" Style="{StaticResource SegmentButton}" GroupName="dashPanel"
                             Content="Live" Tag="live" Checked="PanelButton_Checked" />
              </StackPanel>
            </Border>
          </Grid>
          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ModelsList">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="0,0,10,16" ToolTip="{Binding Tooltip}" Background="Transparent">
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,5">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                 Foreground="{StaticResource InkBrush}"
                                 TextTrimming="CharacterEllipsis" Margin="0,0,10,0" />
                      <TextBlock Grid.Column="1" Text="{Binding CostLabel}" FontSize="13" FontWeight="SemiBold"
                                 Foreground="{StaticResource InkBrush}" />
                    </Grid>
                    <ProgressBar Grid.Row="1" Style="{StaticResource ShareBar}" Value="{Binding Share, Mode=OneWay}"
                                 Foreground="{Binding BarBrush}" />
                    <TextBlock Grid.Row="2" Text="{Binding Detail}" FontSize="11"
                               Foreground="{StaticResource MutedBrush}" Margin="0,5,0,0"
                               TextTrimming="CharacterEllipsis" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>

    <!-- ═══ Ultra real time: live event river ═══ -->
    <Grid x:Name="LiveRoot" Grid.Row="1" Grid.RowSpan="2" Visibility="Collapsed">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Border Grid.Row="0" Style="{StaticResource Card}" Padding="24,18" Margin="0,0,0,14">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" VerticalAlignment="Center" MinWidth="210">
            <TextBlock x:Name="LiveSpendLabel" Text="Spend · last 5 min" Style="{StaticResource TileLabel}" />
            <TextBlock x:Name="LiveSpendText" Text="$0.00" FontSize="44" FontWeight="SemiBold"
                       Foreground="{StaticResource InkBrush}" Margin="0,2,0,0" />
            <StackPanel Orientation="Horizontal" Margin="2,2,0,0">
              <Ellipse x:Name="LivePulseDot" Width="8" Height="8" Fill="{StaticResource AccentBrush}"
                       Opacity="0.35" VerticalAlignment="Center" Margin="0,1,6,0" />
              <TextBlock x:Name="LivePulseText" Text="watching for updates" FontSize="12"
                         Foreground="{StaticResource MutedBrush}" />
            </StackPanel>
          </StackPanel>
          <Border Grid.Column="1" Width="1" Background="{StaticResource GridlineBrush}" Margin="24,4" />
          <UniformGrid Grid.Column="2" Columns="4" VerticalAlignment="Center">
            <StackPanel Margin="6,0">
              <TextBlock x:Name="LiveTokensLabel" Text="Tokens · last 5 min" Style="{StaticResource TileLabel}" />
              <TextBlock x:Name="LiveTokensText" Text="—" Style="{StaticResource TileValue}" />
            </StackPanel>
            <StackPanel Margin="6,0">
              <TextBlock x:Name="LiveMessagesLabel" Text="Responses · last 5 min" Style="{StaticResource TileLabel}" />
              <TextBlock x:Name="LiveMessagesText" Text="—" Style="{StaticResource TileValue}" />
            </StackPanel>
            <StackPanel Margin="6,0">
              <TextBlock Text="Burn rate · 60 s" Style="{StaticResource TileLabel}"
                         ToolTip="Spend over the last 60 seconds, shown per minute." />
              <TextBlock x:Name="LiveRateText" Text="—" Style="{StaticResource TileValue}" />
            </StackPanel>
            <StackPanel Margin="6,0">
              <TextBlock Text="Token rate · 60 s" Style="{StaticResource TileLabel}" />
              <TextBlock x:Name="LiveTokenRateText" Text="—" Style="{StaticResource TileValue}" />
            </StackPanel>
          </UniformGrid>
          <Border Grid.Column="3" Style="{StaticResource SegmentGroup}" VerticalAlignment="Center"
                  ToolTip="Round length: how long the cup fills before it settles into a layer.">
            <StackPanel Orientation="Horizontal">
              <RadioButton x:Name="LiveW1" Style="{StaticResource SegmentButton}" GroupName="liveWindow"
                           Content="60 s" Tag="w1" Checked="LiveWindowButton_Checked" />
              <RadioButton x:Name="LiveW5" Style="{StaticResource SegmentButton}" GroupName="liveWindow"
                           Content="5 m" Tag="w5" IsChecked="True" Checked="LiveWindowButton_Checked" />
              <RadioButton x:Name="LiveW15" Style="{StaticResource SegmentButton}" GroupName="liveWindow"
                           Content="15 m" Tag="w15" Checked="LiveWindowButton_Checked" />
              <RadioButton x:Name="LiveW30" Style="{StaticResource SegmentButton}" GroupName="liveWindow"
                           Content="30 m" Tag="w30" Checked="LiveWindowButton_Checked" />
              <RadioButton x:Name="LiveW45" Style="{StaticResource SegmentButton}" GroupName="liveWindow"
                           Content="45 m" Tag="w45" Checked="LiveWindowButton_Checked" />
              <RadioButton x:Name="LiveW60" Style="{StaticResource SegmentButton}" GroupName="liveWindow"
                           Content="1 h" Tag="w60" Checked="LiveWindowButton_Checked" />
              <RadioButton x:Name="LiveWInf" Style="{StaticResource SegmentButton}" GroupName="liveWindow"
                           Content="∞" Tag="inf" Checked="LiveWindowButton_Checked"
                           ToolTip="Endless: nothing ever settles, the pile just keeps growing." />
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <!-- The whole live feed card moves into the Multi tab's right column and
           back: one live view, one set of state, shown wherever it is needed. -->
      <Border x:Name="LiveFeedCard" Grid.Row="1" Style="{StaticResource Card}" Padding="20,16">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <Grid Grid.Row="0" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock Text="Live feed" FontSize="16" FontWeight="SemiBold"
                         Foreground="{StaticResource InkBrush}" VerticalAlignment="Center" />
              <TextBlock x:Name="LiveRoundText" FontSize="12" FontWeight="SemiBold"
                         Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"
                         Margin="14,1,0,0" />
            </StackPanel>
            <StackPanel x:Name="LiveHeaderControls" Grid.Column="1" Orientation="Horizontal"
                        VerticalAlignment="Top">
              <ItemsControl x:Name="RoundHistoryBars" Height="26" Margin="0,2,12,0"
                            VerticalAlignment="Center">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Width="8" Height="{Binding Height}" Background="{Binding Brush}"
                            CornerRadius="2" Margin="1,0" VerticalAlignment="Bottom"
                            ToolTip="{Binding Tooltip}" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <Border Style="{StaticResource SegmentGroup}"
                      ToolTip="What sizes the blocks (and the value printed on them).">
                <StackPanel Orientation="Horizontal">
                  <RadioButton x:Name="LiveMetricCost" Style="{StaticResource SegmentButton}" GroupName="liveMetric"
                               Content="Cost" Tag="cost" IsChecked="True" Checked="LiveMetricButton_Checked" />
                  <RadioButton x:Name="LiveMetricTokens" Style="{StaticResource SegmentButton}" GroupName="liveMetric"
                               Content="Tokens" Tag="tokens" Checked="LiveMetricButton_Checked" />
                </StackPanel>
              </Border>
            </StackPanel>
          </Grid>
          <ItemsControl x:Name="LiveLegend" Grid.Row="1" Margin="2,4,0,2">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal" Margin="0,0,16,3">
                  <Rectangle Width="10" Height="10" RadiusX="5" RadiusY="5" Fill="{Binding Brush}"
                             VerticalAlignment="Center" />
                  <TextBlock Text="{Binding Name}" FontSize="11" Foreground="{StaticResource Ink2Brush}"
                             Margin="6,0,0,0" />
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <Grid Grid.Row="2" Margin="0,6,0,0" SizeChanged="LiveCanvas_SizeChanged">
            <!-- Round timer as the cup's rim: fills over the round, warms near the end. -->
            <ProgressBar x:Name="RoundProgress" Style="{StaticResource ShareBar}" Height="4"
                         VerticalAlignment="Top" Margin="8,0,8,0" Panel.ZIndex="2"
                         ToolTip="Time until this round settles into a layer." />
            <ScrollViewer x:Name="LiveScroll" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled" Focusable="False"
                          Background="Transparent" BorderThickness="0" Padding="0">
              <Canvas x:Name="LiveCanvas" ClipToBounds="True" Background="Transparent" />
            </ScrollViewer>
            <TextBlock x:Name="LiveEmptyText"
                       Text="Waiting for activity — blocks drop in within about a second of a response being logged."
                       Foreground="{StaticResource MutedBrush}" FontSize="13"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       IsHitTestVisible="False" />
          </Grid>
        </Grid>
      </Border>
    </Grid>

    <!-- ═══ Limits page: one big card per plan limit ═══ -->
    <Grid x:Name="LimitsRoot" Grid.Row="1" Grid.RowSpan="2" Visibility="Collapsed">
      <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                    Focusable="False" BorderThickness="0" Padding="0">
        <StackPanel MaxWidth="860" HorizontalAlignment="Center">
          <Border Style="{StaticResource Card}" Padding="24,18" Margin="0,0,0,14">
            <StackPanel>
              <TextBlock Text="Claude usage limits" FontSize="18" FontWeight="SemiBold"
                         Foreground="{StaticResource InkBrush}" />
              <TextBlock x:Name="LimitsPageSubtitle" FontSize="12"
                         Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"
                         Text="The same numbers Claude Code shows under /usage." />
            </StackPanel>
          </Border>
          <ItemsControl x:Name="LimitsDetailList">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <!-- One card per Claude account, its limits stacked inside. -->
                <Border Style="{StaticResource Card}" Padding="24,18" Margin="0,0,0,14">
                  <StackPanel>
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <StackPanel>
                        <TextBlock Text="{Binding Email}" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource InkBrush}" />
                        <TextBlock Text="{Binding StatusText}" FontSize="12"
                                   Foreground="{Binding StatusBrush}" Margin="0,3,0,0" />
                      </StackPanel>
                      <TextBlock Grid.Column="1" Text="{Binding PlanText}" FontSize="12"
                                 FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"
                                 VerticalAlignment="Top" Margin="16,2,0,0" />
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Limits}" Margin="0,4,0,0">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <StackPanel Margin="0,14,0,0">
                            <Grid>
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                              </Grid.ColumnDefinitions>
                              <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}" />
                                <TextBlock Text="{Binding ResetText}" FontSize="11"
                                           Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0" />
                              </StackPanel>
                              <TextBlock Grid.Column="1" Text="{Binding PercentText}" FontSize="20"
                                         FontWeight="SemiBold" Foreground="{Binding PercentBrush}"
                                         VerticalAlignment="Center" Margin="16,0,0,0" />
                            </Grid>
                            <ProgressBar Style="{StaticResource ShareBar}" Height="8"
                                         Value="{Binding Share, Mode=OneWay}" Foreground="{Binding BarBrush}"
                                         Margin="0,8,0,0" />
                            <!-- Thin companion bar: progress through the window, i.e. how close the reset is. -->
                            <ProgressBar Style="{StaticResource ShareBar}" Height="2"
                                         Value="{Binding ResetShare, Mode=OneWay}"
                                         Foreground="{StaticResource MutedBrush}" Margin="0,3,0,0"
                                         Visibility="{Binding ResetVisibility}"
                                         ToolTip="{Binding ResetTooltip}" />
                          </StackPanel>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBlock x:Name="LimitsPageEmpty" FontSize="13" Foreground="{StaticResource MutedBrush}"
                     TextWrapping="Wrap" TextAlignment="Center" Margin="0,26,0,0" Visibility="Collapsed"
                     Text="No limit data yet. Sign in to Claude Code on this machine and the limits will appear here within a minute." />
        </StackPanel>
      </ScrollViewer>
    </Grid>

    <!-- ═══ Terminals page: one tile per Claude Code session ═══ -->
    <Grid x:Name="TerminalsRoot" Grid.Row="1" Grid.RowSpan="2" Visibility="Collapsed">
      <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                    Focusable="False" BorderThickness="0" Padding="0">
        <StackPanel>
          <Border Style="{StaticResource Card}" Padding="24,18" Margin="0,0,0,14">
            <StackPanel>
              <TextBlock Text="Open terminals" FontSize="18" FontWeight="SemiBold"
                         Foreground="{StaticResource InkBrush}" />
              <TextBlock x:Name="TerminalsSubtitle" FontSize="12"
                         Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"
                         Text="Open terminals, matched to running Claude Code and Codex processes." />
            </StackPanel>
          </Border>
          <ItemsControl x:Name="TerminalsPanel">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Style="{StaticResource Card}" Width="272" Padding="18,14" Margin="0,0,14,14"
                        BorderBrush="{Binding EdgeBrush}" BorderThickness="1"
                        ToolTip="{Binding Tooltip}">
                  <StackPanel>
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <StackPanel Orientation="Horizontal">
                        <Ellipse Width="9" Height="9" Fill="{Binding DotBrush}" VerticalAlignment="Center"
                                 Margin="0,1,8,0" />
                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource InkBrush}" TextTrimming="CharacterEllipsis" />
                      </StackPanel>
                      <Path Grid.Column="1" Data="{Binding IconGeometry}" Fill="{Binding IconBrush}"
                            Width="14" Height="14" Stretch="Uniform" Opacity="0.9"
                            Margin="8,0,0,0" VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock Text="{Binding StatusText}" FontSize="12" FontWeight="SemiBold"
                               Foreground="{Binding StatusBrush}" Margin="17,7,0,0" />
                    <TextBlock Text="{Binding PathText}" FontSize="11"
                               Foreground="{StaticResource MutedBrush}" Margin="17,4,0,0"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBlock x:Name="TerminalsEmpty" FontSize="13" Foreground="{StaticResource MutedBrush}"
                     TextWrapping="Wrap" TextAlignment="Center" Margin="0,26,0,0" Visibility="Collapsed"
                     Text="No Claude Code or Codex terminals are open right now." />
        </StackPanel>
      </ScrollViewer>
    </Grid>

    <!-- ═══ Status strip ═══ -->
    <Grid Grid.Row="3" Margin="2,12,2,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <ProgressBar x:Name="ScanProgress" Width="140" Height="4" Minimum="0" Maximum="1" Value="0"
                     Foreground="{StaticResource AccentBrush}" Background="{StaticResource RaisedBrush}"
                     BorderThickness="0" VerticalAlignment="Center" Margin="0,1,10,0" />
        <TextBlock x:Name="StatusText" Text="Starting…" FontSize="11"
                   Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" />
      </StackPanel>
      <!-- Compact plan limits for the signed-in account; click for the full page. -->
      <StackPanel x:Name="LimitsStrip" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                  Margin="0,0,18,0" Visibility="Collapsed" Cursor="Hand" Background="Transparent"
                  MouseLeftButtonUp="LimitsBar_Clicked" ToolTip="Click for the full limits page.">
        <TextBlock x:Name="LimitsBarAccount" FontSize="11" FontWeight="SemiBold"
                   Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" />
        <ItemsControl x:Name="LimitsPanel" VerticalAlignment="Center">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal" Margin="14,0,0,0" Background="Transparent"
                          ToolTip="{Binding Tooltip}">
                <TextBlock Text="{Binding Label}" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" />
                <ProgressBar Style="{StaticResource ShareBar}" Width="46" Value="{Binding Share, Mode=OneWay}"
                             Foreground="{Binding BarBrush}" VerticalAlignment="Center" Margin="6,1,6,0" />
                <TextBlock Text="{Binding PercentText}" FontSize="11"
                           Foreground="{StaticResource Ink2Brush}" VerticalAlignment="Center" />
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
      <TextBlock x:Name="LastUpdatedText" Grid.Column="2" FontSize="11"
                 Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" />
    </Grid>
  </Grid>
</Window>
